# MAX Web Assistant — Environment Variables
# Copy this file to .env and fill in your keys.
# Add .env to .gitignore — never upload this file!

# Flask secret key (change this to a random string in production)
SECRET_KEY=change-this-to-a-long-random-string-in-production

# OpenWeather API — free at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# NewsAPI — free at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Anthropic / Claude AI — get at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here
